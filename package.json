{
  "name": "go.1ink.us",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "optimize-images": "node scripts/optimize-images.mjs",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "prebuild": "npm run optimize-images && npm run generate-pwa-icons",
    "build": "vite build",
    "postbuild": "node scripts/check-bundle-budget.mjs",
    "browserslist:update": "npx update-browserslist-db@latest",
    "lint": "eslint .",
    "preview": "vite preview",
    "check-dist": "node scripts/check-dist-fresh.mjs",
    "test:e2e": "playwright test e2e/smoke.spec.js",
    "test:a11y": "playwright test e2e/a11y.spec.js e2e/keyboard-path.spec.js",
    "test:e2e:install": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit",
    "validate:projects": "node scripts/validate-projects.mjs",
    "check:health": "node scripts/check-project-health.mjs",
    "test:unit": "node --import tsx --test scripts/test-terminal-parser.mjs scripts/test-loadout-codec.mjs scripts/test-audio-notes.mjs",
    "deploy": "python deploy.py"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
